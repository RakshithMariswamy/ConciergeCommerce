# ─── Backend LLM Proxy Server Configuration ────────────────────────────────
# Copy this file to backend/.env and fill in your API keys
# Used by llm-proxy-server.js to forward LLM requests

# ─── API Keys (at least one required) ──────────────────────────────────────────

# Google Gemini — get free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza...

# OpenAI — get key at https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...

# Anthropic — get key at https://console.anthropic.com
# ANTHROPIC_API_KEY=sk-ant-...

# ─── Server configuration ──────────────────────────────────────────────────────

# Port to listen on (default: 3001)
PORT=3001

# CORS origin — uncomment to restrict to your frontend domain
# CORS_ORIGIN=http://localhost:5173
