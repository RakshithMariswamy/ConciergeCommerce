# ─── Backend Proxy (for CORS-restricted providers) ─────────────────────────
# Set this to enable Gemini or to proxy all requests through a backend.
# Format: http://localhost:3001/api/llm  (dev) or https://your-domain/api/llm (prod)
# When set, ALL provider requests route through the backend (including Anthropic/OpenAI).
# See docs/GEMINI_CORS_SOLUTION.md for setup instructions.
# VITE_LLM_PROXY_URL=http://localhost:3001/api/llm

# ─── Multi-LLM Provider Configuration ──────────────────────────────────────
# Copy this file to .env and set your preferred provider + API key.
# Without any key the app runs in "Local Fallback" mode (no AI calls made).

# Choose your LLM provider: anthropic | openai | gemini  (default: anthropic)
VITE_LLM_PROVIDER=anthropic

# Override the model for the active provider (optional)
# Defaults: anthropic → claude-sonnet-4-6 | openai → gpt-4o | gemini → gemini-2.0-flash
# VITE_LLM_MODEL=claude-sonnet-4-6

# ─── Anthropic ───────────────────────────────────────────────────────────────
# Required when VITE_LLM_PROVIDER=anthropic
# Get a key at https://console.anthropic.com
# VITE_ANTHROPIC_API_KEY=sk-ant-...

# Legacy model override (still honoured for backwards compatibility)
# VITE_ANTHROPIC_MODEL=claude-sonnet-4-6

# ─── OpenAI ──────────────────────────────────────────────────────────────────
# Required when VITE_LLM_PROVIDER=openai
# Get a key at https://platform.openai.com/api-keys
# VITE_OPENAI_API_KEY=sk-...

# ─── Google Gemini ───────────────────────────────────────────────────────────
# ⚠️  BROWSER LIMITATION: Gemini's API endpoint blocks browser requests (CORS).
# 
# To use Gemini, you MUST set VITE_LLM_PROXY_URL to a backend endpoint.
# See docs/GEMINI_CORS_SOLUTION.md for deployment instructions.
#
# Get a free API key at https://aistudio.google.com/apikey
# Supported models: gemini-2.0-flash (default), gemini-1.5-pro, gemini-1.5-flash
#
# VITE_GEMINI_API_KEY=AIza...

# ─── Agent feature gate ──────────────────────────────────────────────────────
# Set to 'false' to force local fallback even when a key is present
# VITE_ENABLE_AGENTS=true

# ─── Security Warning ────────────────────────────────────────────────────────
# ⚠️  These keys are embedded in browser JS (dangerouslyAllowBrowser: true).
# Use ONLY in local development. Never deploy with a real key exposed this way.
# For production: proxy all LLM requests through a backend or Cloudflare Worker.
